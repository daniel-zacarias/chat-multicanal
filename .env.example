# JWT — shared between auth-service and gateway
# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_ISSUER=chat-multicanal

# Database passwords
DB_AUTH_PASSWORD=

# Cassandra application user (created on first init — avoid single quotes in password)
CASSANDRA_USER=history_user
CASSANDRA_PASSWORD=

# Gateway CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
